# =============================================================
# Delta Kinetics — LiveDemo Caddy Reverse Proxy
# Injects DK brand CSS into every HTML response
# Serves static brand assets from /srv/inject/
# =============================================================

{
	# Global options
	admin off
	auto_https off
}

:{$PORT:80} {
	# ── Logging ──────────────────────────────────────────────
	log {
		output stdout
		format json
		level INFO
	}

	# ── Compression ───────────────────────────────────────────
	encode gzip zstd

	# ── Serve brand CSS as static file ───────────────────────
	# Must be declared BEFORE the reverse_proxy catch-all
	handle /dk-brand.css {
		root * /srv/inject
		file_server
		header Cache-Control "public, max-age=3600"
		header Content-Type "text/css; charset=utf-8"
	}

	# ── Health check endpoint (Railway uses this) ─────────────
	handle /caddy-health {
		respond "OK" 200
	}

	# ── Backend-served public pages ──────────────────────────
	# The LiveDemo backend renders these as full HTML server-side.
	# Routing them to the frontend SPA results in an SPA-router
	# 404 fallback (signup page) — verified empirically 2026-04-25.
	#   /livedemos/:storyId  — public demo player (the Strategy C output URL)
	#   /preview/:storyId    — JSON preview for embed clients
	#   /oembed              — oEmbed discovery endpoint
	#   /l/:linkId           — story-link short-uuid resolver (UNVERIFIED — add only if the SPA fails to handle it; current pattern: SPA + JS fetches story by link)
	@backendPaths {
		path /livedemos/* /preview/* /oembed
	}
	handle @backendPaths {
		reverse_proxy livedemo-backend.railway.internal:3005 {
			header_up Host {upstream_hostport}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
			header_down -Server
		}
		replace "</head>" "<link rel=\"stylesheet\" href=\"/dk-brand.css\" />\n</head>"
	}

	# ── Frontend SPA (catch-all) with HTML head injection ───────
	# `replace` from caddy-replace-response streams through the upstream
	# body and rewrites matches. Kept outside reverse_proxy so it acts
	# as a post-handler (handle_response needs a terminal handler like
	# copy_response to emit a modified body — simpler to skip that).
	handle {
		reverse_proxy livedemo-frontend.railway.internal:5000 {
			header_up Host {upstream_hostport}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
			header_down -Server
		}
		replace "</head>" "<link rel=\"stylesheet\" href=\"/dk-brand.css\" />\n</head>"
	}

	# ── Security headers ──────────────────────────────────────
	header {
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}
