{
  "$schema": "https://railway.app/railway.schema.json",
  "services": {
    "livedemo-mongo": {
      "source": { "image": "mongo:8" },
      "deploy": {
        "restartPolicyType": "ON_FAILURE"
      },
      "volumes": [
        { "mountPath": "/data/db", "name": "livedemo-mongo-data" }
      ]
    },
    "livedemo-backend": {
      "source": { "image": "docker.io/livedemo/livedemo-backend:latest" },
      "deploy": {
        "restartPolicyType": "ON_FAILURE",
        "healthcheckPath": "/health",
        "healthcheckTimeout": 30
      }
    },
    "livedemo-frontend": {
      "source": { "image": "docker.io/livedemo/livedemo-web-app:latest" },
      "deploy": {
        "restartPolicyType": "ON_FAILURE"
      }
    },
    "livedemo-proxy": {
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "proxy/Dockerfile",
        "dockerContext": "proxy"
      },
      "deploy": {
        "restartPolicyType": "ON_FAILURE"
      }
    },
    "livedemo-mcp": {
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "mcp/Dockerfile",
        "dockerContext": "mcp"
      },
      "deploy": {
        "startCommand": "node dist/index.js",
        "healthcheckPath": "/health",
        "healthcheckTimeout": 30,
        "restartPolicyType": "ON_FAILURE"
      }
    }
  }
}
