{
  "$schema": "https://railway.app/railway.schema.json",
  "services": {
    "livedemo-mongo": {
      "source": { "image": "mongo:8" },
      "deploy": {
        "restartPolicyType": "ON_FAILURE"
      },
      "volumes": [
        { "mountPath": "/data/db", "name": "livedemo-mongo-data" }
      ]
    },
    "livedemo-backend": {
      "source": { "image": "ghcr.io/matty-1337/dk-livedemo-backend:v1" },
      "deploy": {
        "restartPolicyType": "ON_FAILURE",
        "healthcheckPath": "/health",
        "healthcheckTimeout": 30
      }
    },
    "livedemo-frontend": {
      "source": { "image": "ghcr.io/matty-1337/dk-livedemo-frontend:v1" },
      "deploy": {
        "restartPolicyType": "ON_FAILURE"
      }
    },
    "livedemo-proxy": {
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "proxy/Dockerfile"
      },
      "deploy": {
        "restartPolicyType": "ON_FAILURE"
      }
    },
    "livedemo-mcp": {
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "mcp/Dockerfile"
      },
      "deploy": {
        "startCommand": "node dist/index.js",
        "healthcheckPath": "/health",
        "healthcheckTimeout": 30,
        "restartPolicyType": "ON_FAILURE"
      }
    },
    "livedemo-browser": {
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "browser/Dockerfile"
      },
      "deploy": {
        "startCommand": "node dist/index.js",
        "healthcheckPath": "/health",
        "healthcheckTimeout": 30,
        "restartPolicyType": "ON_FAILURE"
      }
    }
  }
}
