{
  "name": "dk-livedemo-browser",
  "version": "0.1.0",
  "description": "Playwright capture service for DK LiveDemo automated demo generation",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "smoke": "tsx src/scripts/smoke-test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@infisical/sdk": "^3.0.0",
    "fastify": "^4.28.0",
    "playwright": "^1.48.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20"
  }
}
